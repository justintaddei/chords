{
  "name": "chords",
  "displayName": "Chords",
  "description": "Keyboard-centric navigation for VS Code",
  "publisher": "justintaddei",
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#181825",
    "theme": "dark"
  },
  "version": "0.0.4",
  "repository": "https://github.com/justintaddei/chords",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Keymaps"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chords.mode.insert",
        "title": "Chords: Set mode to INSERT"
      },
      {
        "command": "chords.mode.normal",
        "title": "Chords: Set mode to NORMAL"
      },
      {
        "command": "chords.mode.visual",
        "title": "Chords: Set mode to VISUAL"
      },
      {
        "command": "chords.mode.visual-line",
        "title": "Chords: Set mode to VISUAL LINE"
      },
      {
        "command": "chords.mode.visual-block",
        "title": "Chords: Set mode to VISUAL BLOCK"
      },
      {
        "command": "chords.debug",
        "title": "Chords: Toggle verbose logging"
      }
    ],
    "configuration": {
      "title": "Chords",
      "properties": {
        "chords.startIn": {
          "type": "string",
          "enum": [
            "insert",
            "normal",
            "visual",
            "visual line",
            "visual block"
          ],
          "default": "insert",
          "description": "The mode that is selected when VS Code first opens"
        },
        "chords.statusIndicator.priority": {
          "type": "number",
          "default": 100000,
          "description": "The priority of the status indicator (higher values appear further to the left)."
        },
        "chords.leader": {
          "type": "string",
          "default": "<space>",
          "description": "The key to use as the leader key"
        },
        "chords.escape": {
          "type": "string",
          "default": "<escape>",
          "description": "The key to use to exit insert mode"
        },
        "chords.normalMode.lineNumbers": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "relative",
            "interval"
          ],
          "default": "relative",
          "description": "The line numbers to show in normal mode"
        },
        "chords.visualMode.lineNumbers": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "relative",
            "interval"
          ],
          "default": "relative",
          "description": "The line numbers to show in visual mode"
        },
        "chords.normalMode.cursorStyle": {
          "type": "string",
          "enum": [
            "line",
            "block",
            "underline",
            "line-thin",
            "underline-thin",
            "block-outline"
          ],
          "default": "block",
          "description": "The cursor style to use in normal mode"
        },
        "chords.normalMode.operatorPendingCursorStyle": {
          "type": "string",
          "enum": [
            "line",
            "block",
            "underline",
            "line-thin",
            "underline-thin",
            "block-outline"
          ],
          "default": "underline",
          "description": "The cursor style to use in normal mode"
        },
        "chords.visualMode.cursorStyleEmpty": {
          "type": "string",
          "enum": [
            "line",
            "block",
            "underline",
            "line-thin",
            "underline-thin",
            "block-outline"
          ],
          "default": "block-outline",
          "description": "The cursor style to use in visual mode"
        },
        "chords.visualMode.cursorStyleSelection": {
          "type": "string",
          "enum": [
            "line",
            "block",
            "underline",
            "line-thin",
            "underline-thin",
            "block-outline"
          ],
          "default": "line",
          "description": "The cursor style to use in visual mode"
        },
        "chords.selectionHighlightBackgroundColor": {
          "type": "string",
          "default": "rgba(255, 255, 255, 0.5)",
          "description": "The color to use for the selection highlight background"
        },
        "chords.selectionHighlightForegroundColor": {
          "type": "string",
          "default": "rgb(0,0,0)",
          "description": "The color to use for the selection highlight foreground"
        },
        "chords.selectionHighlightDuration": {
          "type": "number",
          "default": 200,
          "description": "The duration in milliseconds to show the selection highlight"
        },
        "chords.keymaps": {
          "type": "array",
          "default": [],
          "items": {
            "type": "array",
            "items": false,
            "prefixItems": [
              {
                "type": "array",
                "items": {
                  "enum": [
                    "normal",
                    "visual"
                  ]
                }
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ]
          },
          "description": "Custom keymaps in the format [[modes], 'before', 'after', 'description']"
        }
      }
    },
    "keybindings": [
      {
        "key": "tab",
        "command": "chords.input",
        "when": "editorTextFocus && !chords.bypass",
        "args": "<tab>"
      },
      {
        "key": "enter",
        "command": "chords.input",
        "when": "editorTextFocus && !chords.bypass",
        "args": "<enter>"
      },
      {
        "key": "escape",
        "command": "chords.input",
        "when": "editorTextFocus",
        "args": "<escape>"
      },
      {
        "key": "backspace",
        "command": "chords.input",
        "when": "editorTextFocus && !chords.bypass",
        "args": "<backspace>"
      },
      {
        "key": "space",
        "command": "chords.input",
        "when": "editorTextFocus && !chords.bypass",
        "args": "<space>"
      },
      {
        "key": "delete",
        "command": "chords.input",
        "when": "editorTextFocus && !chords.bypass",
        "args": "<delete>"
      },
      {
        "key": "ctrl+a",
        "command": "chords.input",
        "when": "editorTextFocus && (chords.listen.<C-a>.normal && chords.effectiveMode == 'normal') || (chords.listen.<C-a>.visual && chords.effectiveMode == 'visual')",
        "args": "<C-a>"
      },
